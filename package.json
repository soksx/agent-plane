{
  "name": "agent-plane",
  "version": "0.1.0",
  "private": true,
  "description": "A multi-tenant platform for running Claude Code agents in isolated Vercel Sandboxes, exposed via a REST API.",
  "license": "MIT",
  "author": "CatalystIQ",
  "repository": {
    "type": "git",
    "url": "https://github.com/getcatalystiq/agent-plane.git"
  },
  "homepage": "https://github.com/getcatalystiq/agent-plane",
  "bugs": {
    "url": "https://github.com/getcatalystiq/agent-plane/issues"
  },
  "keywords": [
    "claude-code",
    "ai-agents",
    "vercel-sandbox",
    "multi-tenant",
    "mcp"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "migrate": "npx tsx src/db/migrate.ts",
    "create-tenant": "npx tsx scripts/create-tenant.ts",
    "sdk:build": "npm run --prefix sdk build",
    "sdk:test": "npm run --prefix sdk test",
    "sdk:typecheck": "npm run --prefix sdk typecheck"
  },
  "dependencies": {
    "@a2a-js/sdk": "0.3.12",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@composio/client": "^0.1.0-alpha.56",
    "@composio/core": "^0.6.3",
    "@neondatabase/serverless": "^1.0.2",
    "@radix-ui/react-popover": "^1.1.15",
    "@tailwindcss/postcss": "^4.1.18",
    "@types/dompurify": "^3.0.5",
    "@uiw/react-codemirror": "^4.25.4",
    "@vercel/blob": "^2.3.1",
    "@vercel/sandbox": "^1.5.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "croner": "^10.0.1",
    "dompurify": "^3.3.1",
    "lucide-react": "^0.564.0",
    "next": "16.1.6",
    "postcss": "^8.5.6",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "recharts": "^3.7.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.1",
    "tailwindcss": "^4.1.18",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/uuid": "^10.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.1.6",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
